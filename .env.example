# --- Orb Cloud ---
# Leave ORB_API_KEY empty to auto-register via ORB_REGISTER_EMAIL.
ORB_API_KEY=
ORB_REGISTER_EMAIL=
ORB_BASE_URL=https://api.orbcloud.dev
ORB_COMPUTER_NAME=orb-exoplanet-hunter
ORB_RUNTIME_MB=8192
ORB_DISK_MB=30720

# --- LLM (weekly red-team + summary) ---
# Z.AI GLM Coding Plan proxy by default — cheaper than native Anthropic for
# the volume of weekly / monthly narrative generation the hunter does.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_MODEL=claude-opus-4-7

# --- Hunter config ---
# Target TESS sectors to initially backfill (range or comma list).
HUNTER_SECTORS=69,70
# Max light curves to process per sector (tune to compute budget).
HUNTER_MAX_TARGETS=5000
# Minimum SDE from TLS to even shortlist.
HUNTER_SDE_FLOOR=8.0
# Dashboard listen port inside the container (NOT ORB_PORT — that's reserved).
HTTP_PORT=8000
